@page "/counter"
@inject AppState AppState
@implements IDisposable

<MudExpansionPanels>
    <MudExpansionPanel Text="Monday" >
     <MudTextField T="string" DisableUnderLine="true" Variant="Variant.Text" FullWidth="true" Lines="10"></MudTextField>
    </MudExpansionPanel>
    <MudExpansionPanel Text="Tuesday" >
       <MudTextField T="string" DisableUnderLine="true" Variant="Variant.Text" FullWidth="true" Lines="10"></MudTextField>
    </MudExpansionPanel>
    <MudExpansionPanel Text="Wednesday">
      <MudTextField T="string" DisableUnderLine="true" Variant="Variant.Text" FullWidth="true" Lines="10"></MudTextField>
    </MudExpansionPanel>
    <MudExpansionPanel Text="Thursday">
       <MudTextField T="string" DisableUnderLine="true" Variant="Variant.Text" FullWidth="true" Lines="10"></MudTextField>
    </MudExpansionPanel>
       <MudExpansionPanel Text="Friday">
       <MudTextField T="string" DisableUnderLine="true" Variant="Variant.Text" FullWidth="true" Lines="10"></MudTextField>
    </MudExpansionPanel>
       <MudExpansionPanel Text="Saturday">
       <MudTextField T="string" DisableUnderLine="true" Variant="Variant.Text" FullWidth="true" Lines="10"></MudTextField>
    </MudExpansionPanel>
       <MudExpansionPanel Text="Sunday">
      <MudTextField T="string" DisableUnderLine="true" Variant="Variant.Text" FullWidth="true" Lines="10"></MudTextField>
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
