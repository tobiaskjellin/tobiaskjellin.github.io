@page "/counter"
@inject AppState AppState
@implements IDisposable

<MudTable Items="@AppState.TestResult" Hover="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh><b>Name</b></MudTh>
        <MudTh><b>Result</b></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Result">@context.Result</MudTd>
    </RowTemplate>
</MudTable>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
