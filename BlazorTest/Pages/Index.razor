@page "/"
@using MudBlazor


<h1>Json Viewer!</h1>

<p>
    <InputFile OnChange="@OnInputFileChange" />
    <button class="btn btn-primary" @onclick="OnGenerateClasses">Generate C# classes</button>
</p>

<MudTreeView Items="@JsonList" MaxHeight="100%" Width="100%">
    <ItemTemplate>
        <MudTreeViewItem @bind-Expanded="@context.IsExpanded" Items="@context.Children">
            <Content>
                <MudTreeViewItemToggleButton @bind-Expanded="@context.IsExpanded" Visible="@context.HasChild" />
                @*<MudIcon Icon="@context.Icon" Class="ml-0 mr-2" Color="@Color.Default" />*@
                <MudText>@context.Bla</MudText>
            </Content>
        </MudTreeViewItem>
    </ItemTemplate>
</MudTreeView>

<p>@classes</p>

@code {
    HashSet<JsonObject> JsonList = new HashSet<JsonObject>();
    string classes = "";

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        IBrowserFile jsonFile = e.File;
        var buffers = new byte[jsonFile.Size];
        await jsonFile.OpenReadStream().ReadAsync(buffers);
        string fileContent = Encoding.UTF8.GetString(buffers);

        using (JsonDocument doc = JsonDocument.Parse(fileContent))
        {
            IterateJsonDocument(null, doc.RootElement, "Root");
        }
    }

    private void IterateJsonDocument(JsonObject parent, JsonElement element, string name)
    {
        if (element.ValueKind is JsonValueKind.Object)
        {
            var jsonObject = new JsonObject(name, string.Empty, element.ValueKind);
            if (parent != null)
                parent.Children.Add(jsonObject);

            parent = jsonObject;

            if (JsonList.Count == 0)
            {
                JsonList.Add(parent);
            }

            var objProperties = element.EnumerateObject();
            foreach (var property in objProperties)
            {
                IterateJsonDocument(parent, property.Value, property.Name);
            }
        }
        else if (element.ValueKind is JsonValueKind.Array)
        {
            var jsonObject = new JsonObject(name, string.Empty, element.ValueKind);
            parent.Children.Add(jsonObject);
            parent = jsonObject;

            var elementArray = element.EnumerateArray();
            foreach (var item in elementArray)
            {
                IterateJsonDocument(parent, item, parent.Children.Count.ToString());
            }
        }
        else
        {
            parent.Children.Add(new JsonObject(name, element.ToString(), element.ValueKind));
        }
    }

    private void OnGenerateClasses()
    {
        if (JsonList.Count > 0)
        {
            //JsonObject root = JsonList[0];
            //PrintClasses(root);
        }
        else
        {
            classes = "Add JSON first";
        }
    }

    private void PrintClasses(JsonObject root)
    {
        if (root.ValueKind == JsonValueKind.Object)
        {
            classes += root.Bla;
        }
        foreach (var item in root.Children)
        {
            if(root.ValueKind == JsonValueKind.Array)
            {

            }
            PrintClasses(item);
        }
    }


    public class JsonObject
    {
        public bool IsExpanded { get; set; } = true;
        public string Name { get; set; }
        public string Value { get; set; }
        public string Bla { get { return string.Format("{0} : {1} <{2}>", Name, Value, ValueKind.ToString()); } }
        public JsonValueKind ValueKind { get; set; }
        public HashSet<JsonObject> Children { get; set; }
        public bool HasChild{ get{return Children.Count > 0;} }

        public JsonObject(string name, string value, JsonValueKind valueKind)
        {
            Name = name;
            Value = value;
            ValueKind = valueKind;
            Children = new HashSet<JsonObject>();
        }
    }
}